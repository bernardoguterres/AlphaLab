# AlphaLab Environment Variables
# Copy this file to .env and fill in your values

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development          # development | production
FLASK_DEBUG=1                  # 1 in dev, 0 in production

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=5000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Data Cache ───────────────────────────────────────────────────────────────
# Directory where downloaded market data is cached (parquet files).
# Relative paths are resolved from the directory you run the server from.
# Default: data/cache  (created automatically on first run)
DATA_CACHE_DIR=data/cache

# ── AlphaSignal Integration (optional) ───────────────────────────────────────
# URL of a running AlphaSignal instance. When set, the backtesting engine
# can enrich signals with sentiment scores from SEC filings and news.
# Leave blank to run AlphaLab standalone without sentiment features.
ALPHASIGNAL_URL=http://localhost:8001
